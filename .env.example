# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env.local y ajusta los valores antes de levantar.
# ──────────────────────────────────────────────────────────────────────────────

# Webhook GET de n8n — devuelve el inventario completo de vSphere
# (hosts, datastores, templates, redes, carpetas, clusters)
N8N_VSPHERE_URL=https://n8n.tudominio.org/webhook/get-vmware-inventory

# Webhook POST de n8n — dispara el workflow de creación de VM
N8N_DEPLOY_URL=https://n8n.tudominio.org/webhook/create-vm

# IP/hostname de ESTE servidor accesible desde la red donde corre n8n
# n8n llamará a: http://<APP_CALLBACK_URL>/api/deploy/callback?jobId=<uuid>
# No usar localhost — debe ser la IP de red real de la máquina host
APP_CALLBACK_URL=http://192.168.1.100:3000
